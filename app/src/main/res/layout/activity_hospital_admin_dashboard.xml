<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_splash"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hospital Admin"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageViewProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@android:color/white" />

            <ImageView
                android:id="@+id/imageViewLogout"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="@android:color/white" />
        </LinearLayout>

        <!-- Last Update / Outdated Banner -->
        <TextView
            android:id="@+id/textViewLastUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Last update: N/A"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewOutdatedBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#FFF3CD"
            android:padding="10dp"
            android:text="Your resource data is outdated. Please update now."
            android:textColor="#7A5A00"
            android:visibility="gone" />

        <!-- Quick Update Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Quick Update"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerQuickResource"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1" />

            <EditText
                android:id="@+id/editTextQuickValue"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:hint="0"
                android:inputType="number" />

            <Button
                android:id="@+id/buttonQuickUpdate"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="Update" />
        </LinearLayout>

        <!-- Medical Resources Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/medical_resources"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="16dp" />

        <!-- ICU Beds -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <EditText
                android:id="@+id/editTextIcuBeds"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/icu_beds_hint"
                android:inputType="number"
                android:padding="12dp"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Oxygen Cylinders -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <EditText
                android:id="@+id/editTextOxygenCylinders"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/oxygen_cylinders_hint"
                android:inputType="number"
                android:padding="12dp"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Ventilators -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <EditText
                android:id="@+id/editTextVentilators"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/ventilators_hint"
                android:inputType="number"
                android:padding="12dp"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Emergency Contact -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusTopStart="8dp">

            <EditText
                android:id="@+id/editTextEmergencyContact"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/emergency_contact_hint"
                android:inputType="phone"
                android:padding="12dp"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Blood Units Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/blood_inventory"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="8dp" />

        <!-- Blood Type Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:spacing="8dp"
            android:layout_marginBottom="8dp">

            <!-- A+ -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodAPositive"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="A+"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- A- -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodANegative"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="A-"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- B+ -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodBPositive"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="B+"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- B- -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodBNegative"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="B-"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Second Row of Blood Types -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:spacing="8dp"
            android:layout_marginBottom="24dp">

            <!-- O+ -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodOPositive"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="O+"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- O- -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodONegative"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="O-"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- AB+ -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodABPositive"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="AB+"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- AB- -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusTopStart="8dp">

                <EditText
                    android:id="@+id/editTextBloodABNegative"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="AB-"
                    android:inputType="number"
                    android:padding="12dp"
                    android:textSize="12sp"
                    android:gravity="center" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Save and Publish Button -->
        <Button
            android:id="@+id/buttonSaveAndPublish"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/save_and_publish"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_background"
            android:layout_marginTop="8dp" />

        <!-- Broadcast Blood Alert Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Blood Requirement Alert"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Broadcast emergency blood requirements to available donors nearby."
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/buttonBroadcastBlood"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/button_background"
                    android:text="Send Blood Requirement Alert"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Progress Indicator -->
        <ProgressBar
            android:id="@+id/progressSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
